# Copy to `.env` and fill in. The Docker deployment reads these at runtime.
# (For the Cloudflare deployment, use `wrangler secret put` instead.)

# --- Required secrets ---

ADMIN_USERNAME=admin

# Format: sha256:<lowercase-hex-sha256-of-password>
# Generate (Linux):
#   IFS= read -r -s -p "Admin password: " PW; echo
#   printf '%s' "$PW" | sha256sum | awk '{print "sha256:" $1}'
#   unset PW
ADMIN_PASSWORD_HASH=sha256:replace-me

# Random secret used to sign session cookies.
# Generate: openssl rand -hex 32
SESSION_SIGNING_SECRET=replace-me

# --- Optional ---

# Listen address inside the container.
# PORT=8787
# HOST=0.0.0.0

# Set to "false" only for local HTTP testing (cookies will then be sent over
# plain HTTP). Production deployments must keep this true and front the server
# with HTTPS via nginx (see nginx.conf.example).
# REMOTE_COOKIE_SECURE=true
