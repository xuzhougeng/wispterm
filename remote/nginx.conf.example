# Example nginx reverse proxy for the WispTerm Remote Console (Docker variant).
#
# Place this in /etc/nginx/sites-available/wispterm-remote (Debian/Ubuntu) or
# /etc/nginx/conf.d/wispterm-remote.conf (RHEL/Alpine), then symlink/enable and
# `nginx -t && systemctl reload nginx`.
#
# Assumes:
#   - The Docker container is published on 127.0.0.1:8787 (see docker-compose.yml).
#   - TLS certificates were issued for `remote.example.com` (e.g. via certbot).
#
# Replace `remote.example.com` with your actual hostname before deploying.

upstream wispterm_remote {
    server 127.0.0.1:8787;
    keepalive 32;
}

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

# Plain HTTP -> HTTPS redirect (also serves ACME challenges).
server {
    listen 80;
    listen [::]:80;
    server_name remote.example.com;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS terminator -> Docker container.
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name remote.example.com;

    ssl_certificate     /etc/letsencrypt/live/remote.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/remote.example.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # WebSocket endpoints — long-lived, need upgrade headers and disabled buffering.
    location ~ ^/ws/ {
        proxy_pass http://wispterm_remote;
        proxy_http_version 1.1;
        proxy_set_header Upgrade            $http_upgrade;
        proxy_set_header Connection         $connection_upgrade;
        proxy_set_header Host               $host;
        proxy_set_header X-Real-IP          $remote_addr;
        proxy_set_header X-Forwarded-For    $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto  $scheme;

        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        proxy_buffering    off;
    }

    # Login API + static SPA assets.
    location / {
        proxy_pass http://wispterm_remote;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
